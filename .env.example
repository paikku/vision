# Base URL for the video normalize microservice.
# Server must expose POST <endpoint> accepting multipart/form-data with field "file"
# and returning video/mp4 on success (non-2xx triggers ffmpeg.wasm fallback on the client).
# Example: FastAPI service from /services/normalize running on localhost:8000
NEXT_PUBLIC_VIDEO_NORMALIZE_ENDPOINT=http://localhost:8000/v1/normalize
